/* =================================================================== */
/* ПЕРЕМЕННЫЕ ДЛЯ PARSER-А (ThemeManager)                              */
/* (Этот блок будет вырезан и не попадет в qApp->setStyleSheet)      */
/* =================================================================== */

@iconColor: #E67E22;
@gridColor: #3c3c3c;

/* =================================================================== */
/* ПАЛИТРА ЦВЕТОВ ТЕМЫ (ДЛЯ ИНФОРМАЦИИ)                                 */
/* =================================================================== */
/*
    ОСНОВНЫЕ
    ЦВЕТ ХОЛСТА: #141414
    ЦВЕТ ТЕКСТА: #e0e0e0
    ЦВЕТ РАМКИ: #333333
    ФОН БОКОВОГО МЕНЮ: rgba(31, 31, 31, 230)
    ФОН ЭЛЕМЕНТОВ УПРАВЛЕНИЯ: #1f1f1f

    КНОПКИ (ОБЫЧНЫЕ)
    ЦВЕТ ФОНА: #E67E22
    ЦВЕТ ТЕКСТА: #141414
    ЦВЕТ ФОНА (НАВЕДЕНИЕ): #F39C12
    ЦВЕТ ТЕКСТА (НАВЕДЕНИЕ): #141414
    ЦВЕТ ФОНА (НАЖАТИЕ): #D35400
    ЦВЕТ ТЕКСТА (НАЖАТИЕ): white

    СПИСКИ И МЕНЮ
    ЦВЕТ ФОНА ВЫПАДАЮЩЕГО СПИСКА: #333333
    ЦВЕТ ВЫДЕЛЕННОГО ЭЛЕМЕНТА: #333333
    ЦВЕТ ЭЛЕМЕНТА (НАВЕДЕНИЕ): #D35400
    ЦВЕТ ВЫБРАННОГО ЭЛЕМЕНТА (ВНУТРИ СПИСКА): #E67E22

    ЭЛЕМЕНТЫ УПРАВЛЕНИЯ (COMBOBOX, SPINBOX)
    ЦВЕТ ФОНА КНОПОК: #E67E22
    ЦВЕТ ФОНА КНОПОК (НАВЕДЕНИЕ): #F39C12

    ЦВЕТ РАЗДЕЛИТЕЛЯ: #333333
*/

/* =================================================================== */
/* ГЛОБАЛЬНЫЕ СТИЛИ                                                    */
/* =================================================================== */

QWidget {
    background-color: #141414;
    color: #e0e0e0;
    font-size: 14px;
}

/* Кнопки типа "Применить", "Отмена" */
QPushButton {
    background-color: #E67E22;
    color: #141414;
    padding: 10px 20px;
    border: none;
    border-radius: 5px;
}

QPushButton:hover {
    background-color: #F39C12;
    color: #141414;
}

QPushButton:pressed {
    background-color: #D35400;
    color: white;
}

/* =================================================================== */
/* СТИЛИ ПОЛОСЫ ПРОКРУТКИ                                              */
/* =================================================================== */

QScrollArea#hotkeysScrollArea QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 8px;
    margin: 0px;
}
QScrollArea#hotkeysScrollArea QScrollBar::handle:vertical {
    background-color: #D35400;
    border-radius: 4px;
    min-height: 25px;
}
QScrollArea#hotkeysScrollArea QScrollBar::handle:vertical:hover {
    background-color: #E67E22;
}
QScrollArea#hotkeysScrollArea QScrollBar::handle:vertical:pressed {
    background-color: #F39C12;
}
QScrollArea#hotkeysScrollArea QScrollBar::add-line:vertical,
QScrollArea#hotkeysScrollArea QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

/* =================================================================== */
/* СТИЛИ КОНКРЕТНЫХ КОМПОНЕНТОВ                                        */
/* =================================================================== */

/* ----- Холст ----- */
CanvasView {
    border: none;
}

/* ----- Боковая панель инструментов ----- */
FloatingToolBar {
    background-color: rgba(31, 31, 31, 230);
    border: 3px solid #333333;
    border-radius: 12px;
}
FloatingToolBar QToolButton {
    background-color: transparent;
    border: none;
    padding: 8px;
    margin: 2px;
    border-radius: 6px;
}
FloatingToolBar QToolButton:hover {
    background-color: #505050;
}
FloatingToolBar QToolButton:pressed {
    background-color: #5a5a5a;
}
FloatingToolBar QFrame#toolBarSeparator {
    background-color: #333333;
    height: 1px;
    border: none;
    margin: 5px 5px;
}

/* ----- Окно настроек ----- */
QListWidget#settingsNavigationList {
    border: 1px solid #333333;
    border-radius: 12px;
    outline: 0;
    padding: 3px;
}
QListWidget#settingsNavigationList::item {
    border-radius: 10px;
    margin-bottom: 4px;
    padding: 10px;
}
QListWidget#settingsNavigationList::item:selected {
    background-color: #E67E22;
    color: #141414;
}
QListWidget#settingsNavigationList::item:hover {
    background-color: #D35400;
}

/* Правый список настроек */
SettingsDialog  QStackedWidget > QWidget {
    border: 1px solid #333333;
    border-radius: 12px;
    padding: 5px;
}

QLabel#hotkeySectionHeader {
    color: #e0e0e0;
    font-weight: bold;
    font-size: 15px;
    padding-top: 5px;
    padding-bottom: 5px;
    margin-bottom: 5px;
    margin-left: 5px;
    border-bottom: 1px solid #E67E22;
}

/* Элементы управления */
SettingsDialog QSpinBox, SettingsDialog QComboBox {
    background-color: #1f1f1f;
    border: 1px solid #333333;
    border-radius: 4px;
    padding: 5px;
}
SettingsDialog QComboBox {
    width: 166px;
}
SettingsDialog QSpinBox {
    min-width: 180px;
}
SettingsDialog QSpinBox:hover, SettingsDialog QComboBox:hover {
    border-color: #E67E22;
}
SettingsDialog QComboBox QAbstractItemView {
    background-color: #333333;
    border: 1px solid #E67E22;
    border-radius: 4px;
    padding: 4px;
}
SettingsDialog QComboBox QAbstractItemView::item {
    font-size: 15px;
    min-height: 28px;
    padding-left: 10px;
    background-color: transparent;
    border-radius: 4px;
}
SettingsDialog QComboBox QAbstractItemView::item:hover {
    background-color: #D35400;
}
SettingsDialog QComboBox QAbstractItemView::item:selected {
    background-color: #E67E22;
}
SettingsDialog QComboBox::indicator {
    width: 20px;
    height: 20px;
}
SettingsDialog QComboBox::indicator:checked {
    image: url(:/icons/icons/checkmark-light.svg);
}
SettingsDialog QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px;
    background-color: #E67E22;
    border-left: 1px solid #333333;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
}
SettingsDialog QComboBox::drop-down:hover {
    background-color: #F39C12;
}
SettingsDialog QComboBox::down-arrow {
    image: url(:/icons/icons/arrow-down-dark.svg);
}

/* Кнопки вверх/вниз у QSpinBox */
SettingsDialog QSpinBox::up-button,
SettingsDialog QSpinBox::down-button {
    subcontrol-origin: padding;
    width: 25px;
    background-color: #E67E22;
    border-left: 1px solid #333333;
}
SettingsDialog QSpinBox::up-button:hover,
SettingsDialog QSpinBox::down-button:hover {
    background-color: #F39C12;
}
SettingsDialog QSpinBox::up-button {
    subcontrol-position: top right;
    border-top-right-radius: 3px;
}
SettingsDialog QSpinBox::down-button {
    subcontrol-position: bottom right;
    border-bottom-right-radius: 3px;
}
SettingsDialog QSpinBox::up-arrow {
    image: url(:/icons/icons/arrow-up-dark.svg);
}
SettingsDialog QSpinBox::down-arrow {
    image: url(:/icons/icons/arrow-down-dark.svg);
}

/* Окно приветствия */
#welcomeTitle {
    font-size: 72px;
    font-weight: bold;
    color: #e0e0e0;
}
#welcomeButton {
    font-size: 18px;
    padding: 10px 20px;
    color: #141414;
    background-color: #E67E22;
    border: none;
    border-radius: 5px;
}
#welcomeButton:hover {
    background-color: #F39C12;
}
#welcomeButton:pressed {
    background-color: #D35400;
    color: white;
}
